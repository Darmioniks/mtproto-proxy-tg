# Байт-код Python
__pycache__/
*.py[cod]
*$py.class
*.pyo

# Виртуальное окружение
venv/
.venv/
env/
ENV/

# Переменные окружения
.env

# Дистрибутивы
dist/
build/
*.egg-info/
*.egg

# Покрытие тестов
htmlcov/
.coverage
.coverage.*
.pytest_cache/
.mypy_cache/

# Jupyter Notebooks
.ipynb_checkpoints/

# IDE
.idea/
.vscode/
*.swp

